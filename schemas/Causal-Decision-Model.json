{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Causal-Decision-Model",
  "type": "object",
  "required": ["meta", "diagrams"],
  "properties": {
    "meta": { "type": "object" },
    "diagrams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["elements", "dependencies"],
        "properties": {
          "elements": { "type": "array" },
          "dependencies": { "type": "array" }
        }
      }
    }
  }
}
