{
  "$schema": "../schemas/Causal-Decision-Model.json",
  "meta": {
    "uuid": "af68dfd2-c1fd-401c-a6c3-3faf87d6d9b6",
    "name": "SKEL-03: Quality Management",
    "summary": "Canonical skeleton for quality management. Six Levers, five Externals, seven Intermediates, four Outcomes. 35 causal dependencies.",
    "documentation": {
      "content": "KODI Lite \u00b7 SKEL-03 \u00b7 Quality Management\n\nLevers (6): Inspection Intensity, Acceptance Threshold, Sampling Plan, Rework Authorisation Policy, SPC Trigger Threshold, Corrective Action Speed\nExternals (5): Incoming Material Quality, Process Environment Conditions, Customer Specification Tolerance, Supplier Consistency, Regulatory Quality Standards\nIntermediates (7): Process Capability Index [I1 = w1*E5 - w2*E1 - w3*E2 - w4*E4 + w5*A5 + b], In-Process Defect Rate [I2 = -w1*I1 + w2*E1 + w3*E2 + w4*E3 + w5*A2 - w6*A5 + w7*I4 + w8*I7 + b], Inspection Throughput [I3 = -w1*A1 - w2*A3 + b], Rework Volume [I4 = w1*I2 + w2*A4 + b], Scrap Rate [I5 = w1*I2 + w2*A2 - w3*A4 + b], First-Pass Yield [I6 = -w1*I2 + w2*A1 + b], Corrective Action Lag [I7 = -w1*A6 + b]\nOutcomes (4): Product Conformance Rate [maximise], Quality Cost per Unit [minimise], Customer Return Rate [minimise], Warranty Liability [minimise]",
      "MIMEType": "text/plain"
    },
    "version": "1.0",
    "draft": false,
    "createdDate": "2026-07-01T09:00:00Z"
  },
