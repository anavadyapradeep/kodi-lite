            "uuid": "dep-e001-i001",
            "name": "E_demand_forecast → I_capacity_utilization",
            "description": "Higher demand forecast drives higher planned production volume, directly increasing required capacity utilisation."
          },
          "source": "e001-0000-0000-0000-000000000001",
          "target": "i001-0000-0000-0000-000000000001"
        },
        {
          "meta": {
            "uuid": "dep-e001-i003",
            "name": "E_demand_forecast → I_finished_goods_inventory",
            "description": "Demand forecast sets the required finished goods buffer. When forecast rises, target inventory level rises."
          },
          "source": "e001-0000-0000-0000-000000000001",
          "target": "i003-0000-0000-0000-000000000003"
        },
        {
          "meta": {
            "uuid": "dep-e002-i001",
            "name": "E_raw_material_availability → I_capacity_utilization",
            "description": "Material shortages cap achievable production volume and reduce effective capacity utilisation regardless of scheduled load."
          },
          "source": "e002-0000-0000-0000-000000000002",
          "target": "i001-0000-0000-0000-000000000001"
        },
        {
          "meta": {
            "uuid": "dep-e002-i002",
            "name": "E_raw_material_availability → I_wip_level",
            "description": "Material shortages stall in-process batches, accumulating WIP at material-constrained workstations."
          },
          "source": "e002-0000-0000-0000-000000000002",
          "target": "i002-0000-0000-0000-000000000002"
        },
        {
          "meta": {
            "uuid": "dep-e002-i004",
            "name": "E_raw_material_availability → I_lead_time",
            "description": "Material delays extend production lead time directly — a missing component halts the batch until supply arrives."
          },
          "source": "e002-0000-0000-0000-000000000002",
          "target": "i004-0000-0000-0000-000000000004"
        },
        {
          "meta": {
            "uuid": "dep-e003-i001",
            "name": "E_regulatory_constraints → I_capacity_utilization",
            "description": "Compliance requirements (emission limits, safety shutdowns, permit windows) consume capacity hours, reducing effective utilisation ceiling."
          },
          "source": "e003-0000-0000-0000-000000000003",
          "target": "i001-0000-0000-0000-000000000001"
        },
        {
          "meta": {
            "uuid": "dep-e004-i001",
            "name": "E_market_conditions → I_capacity_utilization",
            "description": "Market downturns reduce order intake, causing planned load to fall below available capacity — utilisation drops."
          },
          "source": "e004-0000-0000-0000-000000000004",
          "target": "i001-0000-0000-0000-000000000001"
        },
        {
          "meta": {
            "uuid": "dep-e004-i003",
            "name": "E_market_conditions → I_finished_goods_inventory",
            "description": "Weak market conditions slow order fulfilment, causing finished goods to accumulate. Strong conditions drain them."
          },
          "source": "e004-0000-0000-0000-000000000004",
          "target": "i003-0000-0000-0000-000000000003"
        },

        {
          "meta": {
            "uuid": "dep-a001-i001",
            "name": "A_production_volume_per_sku → I_capacity_utilization",
            "description": "Higher planned production volume directly increases the load on available capacity, raising utilisation rate."
          },
          "source": "a001-0000-0000-0000-000000000001",
          "target": "i001-0000-0000-0000-000000000001"
        },
        {
          "meta": {
            "uuid": "dep-a001-i002",
            "name": "A_production_volume_per_sku → I_wip_level",
            "description": "Scheduling more volume simultaneously increases in-process inventory as more batches are staged at once."
          },
          "source": "a001-0000-0000-0000-000000000001",
          "target": "i002-0000-0000-0000-000000000002"
        },
        {
          "meta": {
            "uuid": "dep-a001-i003",
            "name": "A_production_volume_per_sku → I_finished_goods_inventory",
            "description": "Volume decisions set the production output rate; higher output directly increases finished goods stock when not immediately fulfilled."
          },
          "source": "a001-0000-0000-0000-000000000001",
          "target": "i003-0000-0000-0000-000000000003"
        },
        {
          "meta": {
            "uuid": "dep-a002-i001",
            "name": "A_production_mix → I_capacity_utilization",
            "description": "Different SKUs carry different cycle times and changeover requirements. A high-complexity mix raises effective load per unit scheduled."
          },
          "source": "a002-0000-0000-0000-000000000002",
          "target": "i001-0000-0000-0000-000000000001"
        },
        {
          "meta": {
            "uuid": "dep-a002-i002",
            "name": "A_production_mix → I_wip_level",
            "description": "Complex or high-variety mixes increase WIP as more concurrent part numbers are staged across the production floor."
          },
          "source": "a002-0000-0000-0000-000000000002",
          "target": "i002-0000-0000-0000-000000000002"
        },
        {
          "meta": {
            "uuid": "dep-a003-i001",
            "name": "A_shift_count → I_capacity_utilization",
            "description": "Adding shifts expands the total available machine-hours denominator. At constant load, utilisation rate falls. Shift count is the primary short-run lever to change the utilisation operating point."
          },
          "source": "a003-0000-0000-0000-000000000003",
          "target": "i001-0000-0000-0000-000000000001"
        },
        {
          "meta": {
            "uuid": "dep-a003-i004",
            "name": "A_shift_count → I_lead_time",
            "description": "More shifts reduce queue waiting time for work orders, compressing overall production lead time."
          },
          "source": "a003-0000-0000-0000-000000000003",
          "target": "i004-0000-0000-0000-000000000004"
        },
        {
          "meta": {
            "uuid": "dep-a004-i001",
            "name": "A_line_allocation → I_capacity_utilization",
            "description": "Efficient line allocation minimises inter-line transport and setup, improving effective utilisation of committed capacity."
          },
          "source": "a004-0000-0000-0000-000000000004",
          "target": "i001-0000-0000-0000-000000000001"
        },
        {
          "meta": {
            "uuid": "dep-a004-i002",
            "name": "A_line_allocation → I_wip_level",
            "description": "Poor line allocation creates cross-line dependencies that stall batches and inflate WIP buffers."
          },
          "source": "a004-0000-0000-0000-000000000004",
          "target": "i002-0000-0000-0000-000000000002"
        },
        {
          "meta": {
            "uuid": "dep-a005-i002",
            "name": "A_batch_sequencing → I_wip_level",
            "description": "Optimal batch sequencing (minimising changeovers between dissimilar batches) reduces non-productive idle time in the WIP queue."
          },
          "source": "a005-0000-0000-0000-000000000005",
          "target": "i002-0000-0000-0000-000000000002"
        },
        {
          "meta": {
            "uuid": "dep-a005-i004",
            "name": "A_batch_sequencing → I_lead_time",
            "description": "Better sequencing reduces cumulative changeover time per planning cycle, which directly compresses average production lead time."
          },
          "source": "a005-0000-0000-0000-000000000005",
          "target": "i004-0000-0000-0000-000000000004"
        },

        {
          "meta": {
            "uuid": "dep-i001-o001",
            "name": "I_capacity_utilization → O_fulfillment_rate",
            "description": "When capacity is over-utilised, the factory cannot meet all orders; fulfillment rate falls. When under-utilised, capacity exists to fulfil all demand."
          },
          "source": "i001-0000-0000-0000-000000000001",
          "target": "o001-0000-0000-0000-000000000001"
        },
        {
          "meta": {
            "uuid": "dep-i001-o002",
            "name": "I_capacity_utilization → O_unit_cost",
            "description": "Fixed overhead spread across more units at higher utilisation reduces unit cost. Very low utilisation inflates per-unit fixed cost allocation."
          },
          "source": "i001-0000-0000-0000-000000000001",
          "target": "o002-0000-0000-0000-000000000002"
        },
        {
          "meta": {
            "uuid": "dep-i002-o002",
            "name": "I_wip_level → O_unit_cost",
            "description": "High WIP represents cash tied up in in-process inventory and signals inefficiency. Carrying costs and risk of write-down increase effective unit cost."
          },
          "source": "i002-0000-0000-0000-000000000002",
          "target": "o002-0000-0000-0000-000000000002"
        },
        {
          "meta": {
            "uuid": "dep-i002-o003",
            "name": "I_wip_level → O_on_time_delivery",
            "description": "Elevated WIP signals flow congestion that extends cycle time across all batches, degrading on-time delivery performance."
          },
          "source": "i002-0000-0000-0000-000000000002",
          "target": "o003-0000-0000-0000-000000000003"
        },
        {
          "meta": {
            "uuid": "dep-i003-o001",
            "name": "I_finished_goods_inventory → O_fulfillment_rate",
            "description": "Adequate finished goods buffer allows immediate order fulfilment without waiting for production. Directly and strongly determines fulfillment rate."
          },
          "source": "i003-0000-0000-0000-000000000003",
          "target": "o001-0000-0000-0000-000000000001"
        },
        {
          "meta": {
            "uuid": "dep-i003-o002",
            "name": "I_finished_goods_inventory → O_unit_cost",
            "description": "Excess finished goods inventory incurs holding costs (warehousing, insurance, obsolescence risk) that increase effective unit cost of goods sold."
          },
          "source": "i003-0000-0000-0000-000000000003",
          "target": "o002-0000-0000-0000-000000000002"
        },
        {
          "meta": {
            "uuid": "dep-i004-o003",
            "name": "I_lead_time → O_on_time_delivery",
            "description": "Lead time is the primary driver of on-time delivery. When lead time exceeds the customer's order-to-ship window, deliveries become late."
          },
          "source": "i004-0000-0000-0000-000000000004",
          "target": "o003-0000-0000-0000-000000000003"
        },
        {
          "meta": {
            "uuid": "dep-i004-o001",
            "name": "I_lead_time → O_fulfillment_rate",
            "description": "Long lead times prevent fulfilment from available production capacity — finished goods are not yet ready when the order window closes."
          },
          "source": "i004-0000-0000-0000-000000000004",
          "target": "o001-0000-0000-0000-000000000001"
        },

        {
          "meta": {
            "uuid": "dep-a001-o002",
            "name": "A_production_volume_per_sku → O_unit_cost",
            "description": "Direct volume effect on unit cost: higher volume spreads fixed costs (tooling, setup, overhead) across more units, reducing per-unit cost."
          },
          "source": "a001-0000-0000-0000-000000000001",
          "target": "o002-0000-0000-0000-000000000002"
        },
        {
          "meta": {
            "uuid": "dep-a002-o004",
            "name": "A_production_mix → O_gross_margin",
            "description": "Shifting mix toward higher-margin SKUs directly improves overall gross margin, independent of cost efficiency."
          },
          "source": "a002-0000-0000-0000-000000000002",
          "target": "o004-0000-0000-0000-000000000004"
        },
        {
          "meta": {
            "uuid": "dep-a003-o002",
            "name": "A_shift_count → O_unit_cost",
            "description": "Each additional shift adds labour premium and energy cost. Beyond a volume threshold, the extra cost per unit from shift premiums can outweigh volume savings."
          },
          "source": "a003-0000-0000-0000-000000000003",
          "target": "o002-0000-0000-0000-000000000002"
        },
        {
          "meta": {
            "uuid": "dep-o001-o004",
            "name": "O_fulfillment_rate → O_gross_margin",
            "description": "Unfulfilled orders represent lost revenue. High fulfillment rate protects the revenue numerator of the gross margin calculation."
          },
          "source": "o001-0000-0000-0000-000000000001",
          "target": "o004-0000-0000-0000-000000000004"
        },
        {
          "meta": {
            "uuid": "dep-o002-o004",
            "name": "O_unit_cost → O_gross_margin",
            "description": "Unit cost is the primary component of COGS. Lower unit cost directly expands gross margin at any given selling price."
          },
          "source": "o002-0000-0000-0000-000000000002",
          "target": "o004-0000-0000-0000-000000000004"
        },
        {
          "meta": {
            "uuid": "dep-e004-o004",
            "name": "E_market_conditions → O_gross_margin",
            "description": "Market price pressure directly affects revenue per unit sold. Inflationary conditions can expand margin; deflationary/competitive pressure compresses it."
          },
          "source": "e004-0000-0000-0000-000000000004",
          "target": "o004-0000-0000-0000-000000000004"
        }
      ]
    }
